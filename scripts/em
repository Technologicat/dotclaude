#!/usr/bin/env bash
# Open file(s) in Emacs. Without arguments, starts Emacs.
# With --require-server (-r), fail if no server is running (for scripts/automation).
#
# Why this exists: Emacs ships the *mechanism* — server mode, and emacsclient to
# talk to it — but punts on the UX around it. Bare emacsclient doesn't decide
# whether a frame needs creating, doesn't start a daemon if none is running unless
# told to, and won't raise the window it just opened your file in. So the file
# lands in an Emacs you can't see, which is the same as not opening it. This
# wrapper makes the three decisions:
#
#   - no frame open  -> create one (-c), starting a daemon if needed (-a '')
#   - frame open     -> reuse it
#   - either way     -> raise the window (wmctrl), so the file is actually in front of you
#
# Deploy by symlinking onto PATH, so this stays the single copy:
#
#     ln -s ~/.claude/scripts/em ~/.local/bin/em
#
# Needs emacsclient and wmctrl.

require_server=false
args=()
for arg in "$@"; do
    case "$arg" in
        --require-server|-r) require_server=true ;;
        *) args+=("$arg") ;;
    esac
done

if $require_server; then
    if ! emacsclient -n -e "t" &>/dev/null; then
        echo "error: no Emacs server running" >&2
        exit 1
    fi
fi

# Check if there's an Emacs frame open
emacsclient -n -e "(if (> (length (frame-list)) 1) 't)" 2>/dev/null | grep t &>/dev/null

if [ "$?" -eq "1" ]; then
    emacsclient -a '' -nqc "${args[@]}" &>/dev/null
else
    emacsclient -nq "${args[@]}" &>/dev/null
fi

# Focus the Emacs window
wmctrl -a emacs
